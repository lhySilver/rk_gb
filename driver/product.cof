[STATION]
#需要连接路由的 名称(等号后面直接填写，不要加其他无关字符/符号，空代表不连接)
stationssid=DGIOT
#需要连接路由的 密码(等号后面直接填写，不要加其他无关字符/符号)
stationpwd=dgiot0202

ipaddr=192.168.110.56
netmask=255.255.255.0
gateway=192.168.110.1

[CONST_PARAM]
#白光灯控制逻辑 0-正 高电平亮灯，低电平关灯，1-反 高电平关灯，低电平亮灯
light_ctrl=0


#通过在web端输入，切换测试模式
#http://192.168.110.56/get?cal=0    拼接标定 	
#http://192.168.110.56/get?cal=1    白平衡标定
#http://192.168.110.56/get?cal=2    产测测试
